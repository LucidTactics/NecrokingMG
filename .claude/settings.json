{
  "permissions": {
    "allow": [
      "mcp__necroking__necro_status",
      "mcp__necroking__necro_start",
      "mcp__necroking__necro_cmd",
      "mcp__necroking__necro_screenshot",
      "mcp__necroking__necro_restart",
      "mcp__necroking__necro_stop",
      "Bash(python tools/devctl.py:*)",
      "Bash(py tools/devctl.py:*)",
      "Bash(python3 tools/devctl.py:*)",
      "Bash(python -m py_compile:*)",
      "Bash(py -m py_compile:*)",
      "Bash(python3 -m py_compile:*)",
      "Bash(python tools/hooks/:*)",
      "Bash(py tools/hooks/:*)",
      "Bash(python3 tools/hooks/:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(awk:*)",
      "Bash(tail:*)",
      "Bash(head:*)",
      "Bash(cut:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(xargs grep:*)",
      "Bash(python tools/json_data.py:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/tools/hooks/bash_prompt_guard.py\"",
            "shell": "bash",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/tools/hooks/allow_locate_behavior_writes.py\"",
            "shell": "bash",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
